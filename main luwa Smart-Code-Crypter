-- Clipboard Master Manager
local function copyToClipboard(label, textData)
  pcall(function()
    if Build.VERSION.SDK_INT >= 11 then
      local clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
      local clip = ClipData.newPlainText(label, textData)
      clipboard.setPrimaryClip(clip)
    else
      local clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
      clipboard.setText(textData)
    end
  end)
end

