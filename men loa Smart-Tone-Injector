-- 7. Inject Button
views.btnInject.setOnClickListener({
  onClick = function(v)
    if selectedExtensionFolder == "" then
      speakText("Pehle target extension select karein!")
      return
    end
    
    local targetPath = currentSearchPath .. selectedExtensionFolder .. "/main.lua"
    if not File(targetPath).exists() then
      speakText("main.lua not found in selected folder!")
      return
    end
    
    local file = io.open(targetPath, "r")
    if not file then
      speakText("Cannot read file!")
      return
    end
    local content = file:read("*all")
    file:close()
    
    local pattern = "%-%-% Smart_Tone_Injector_Active_Block.-%-%-% Smart_Tone_Injector_End_Block"
    content = content:gsub(pattern, "")
    content = content:gsub("\n\n\n+", "\n\n")
    
    local injection = generateToneCode()
    content = content .. "\n" .. injection
    
    file = io.open(targetPath, "w")
    if not file then
      speakText("Cannot write file!")
      return
    end
    file:write(content)
    file:close()
    
    speakText("✅ Tone successfully injected into " .. selectedExtensionFolder)
  end
})

