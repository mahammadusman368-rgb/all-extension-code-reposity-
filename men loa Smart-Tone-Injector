    local file = io.open(targetPath, "r")
    if not file then
      speakText("Cannot read file!")
      return
    end
    local content = file:read("*all")
    file:close()
    
    -- FIXED PATTERN FOR REMOVAL
    local pattern = "%-%-% Smart_Tone_Injector_Active_Block.-%-%-% Smart_Tone_Injector_End_Block"
    local newContent, count = content:gsub(pattern, "")
    
    if count == 0 then
      speakText("❌ Koi injected tone nahi mili!")
      return
    end
    
    -- Clean extra newlines
    newContent = newContent:gsub("\n\n\n+", "\n\n"):gsub("[\n\r]+$", "")
    
    file = io.open(targetPath, "w")
    if not file then
      speakText("Cannot write file!")
      return
    end
    file:write(newContent)
    file:close()
    
    speakText("🗑️ Tone removed successfully!")
  end
})

