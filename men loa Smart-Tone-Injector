-- Get Folder List Function
local function getFolderList(path)
  local list = {}
  local folder = File(path)
  if folder.exists() then
    local files = folder.listFiles()
    if files then
      for i = 0, #files - 1 do
        if files[i].isDirectory() then
          if File(files[i].getAbsolutePath() .. "/main.lua").exists() then
            table.insert(list, tostring(files[i].getName()))
          end
        end
      end
    end
  end
  return list
end

