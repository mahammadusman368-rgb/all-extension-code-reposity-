local function playTonePreview()
  if currentToneType == "builtin" then
    pcall(function() 
      local toneG = ToneGenerator(AudioManager.STREAM_NOTIFICATION, 100) 
      toneG.startTone(selectedBuiltinId, 250) 
    end)
  elseif currentToneType == "custom" then
    if selectedCustomPath == "" or not File(selectedCustomPath).exists() then 
      speakText("Meherbani karke pehle valid audio select karein!") 
      return 
    end
    pcall(function() 
      if globalMediaPlayer then 
        globalMediaPlayer.stop() 
        globalMediaPlayer.release() 
        globalMediaPlayer = nil 
      end 
      globalMediaPlayer = MediaPlayer() 
      globalMediaPlayer.setDataSource(ctx, Uri.fromFile(File(selectedCustomPath))) 
      globalMediaPlayer.prepare() 
      globalMediaPlayer.start() 
    end)
  end
end

local function scanStorageForShortTones(dirPath)
  local files = File(dirPath).listFiles()
  if not files then return end
  for i = 0, #files - 1 do
    local file = files[i]
    if file.isDirectory() then
      local name = tostring(file.getName())
      if not name:find("^%.") and name ~= "Android" and name ~= "Data" then 
        scanStorageForShortTones(file.getAbsolutePath()) 
      end
    elseif file.isFile() then
      local path = tostring(file.getAbsolutePath())
      if path:match("%.mp3$") or path:match("%.wav$") or path:match("%.ogg$") then
        pcall(function()
          local retriever = MediaMetadataRetriever()
          retriever.setDataSource(path)
          local durationStr = retriever.extractMetadata(MediaMetadataRetriever.METADATA_KEY_DURATION)
          retriever.release()
          if durationStr and tonumber(durationStr) <= 10000 then 
            table.insert(scannedTonesList, file.getName()) 
            table.insert(scannedTonesPaths, path) 
          end
        end)
      end
    end
  end
end

